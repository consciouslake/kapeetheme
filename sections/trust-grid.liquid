{%- style -%}
  .trust-grid {
    padding: 40px 0;
    background-color: #f8f8f8;
    border-top: 1px solid #eee;
    border-bottom: 1px solid #eee;
  }
  .trust-grid__container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    text-align: center;
  }
  .trust-item {
    padding: 10px;
  }
  .trust-item h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 5px;
    color: #333;
    text-transform: uppercase;
  }
  .trust-item p {
    font-size: 13px;
    color: #666;
    margin: 0;
  }
  @media screen and (max-width: 749px) {
    .trust-grid__container {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{%- endstyle -%}

<div class="trust-grid">
  <div class="trust-grid__container page-width">
    <div class="trust-item">
      <h3>Free Shipping</h3>
      <p>No min. purchase required</p>
    </div>
    <div class="trust-item">
      <h3>Lowest Price Guarantee*</h3>
      <p>Best deals</p>
    </div>
    <div class="trust-item">
      <h3>15 Days Return</h3>
      <p>Simply return within 15 days*</p>
    </div>
    <div class="trust-item">
      <h3>Support</h3>
      <p>10AM - 7PM (Mon to Sat)</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Grid",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Trust Grid"
    }
  ]
}
{% endschema %}
