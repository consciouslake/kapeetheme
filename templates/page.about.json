{
  "sections": {
    "main": {
      "type": "main-page",
      "settings": {
        "padding_top": 28,
        "padding_bottom": 28
      }
    },
    "banner": {
      "type": "image-banner",
      "settings": {
        "image_height": "small",
        "desktop_content_position": "middle-center",
        "show_text_box": false,
        "desktop_content_alignment": "center",
        "color_scheme": "scheme-4"
      }
    },
    "story": {
      "type": "rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Our Story",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Acutastore was founded with a simple mission: to bring premium quality auto and home essentials to every doorstep in India. We believe in quality, reliability, and excellent customer service.<\/p>"
          }
        }
      },
      "block_order": [
        "heading",
        "text"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "full_width": false,
        "padding_top": 40,
        "padding_bottom": 40
      }
    }
  },
  "order": [
    "main",
    "banner",
    "story"
  ]
}
