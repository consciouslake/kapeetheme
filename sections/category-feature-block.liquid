{%- style -%}
  .cat-feature-section {
    padding: 0 !important;
    max-width: var(--page-width);
    margin: 80px auto !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    border-top: 2px solid #2874f0;
    padding-top: 40px !important;
  }

  .cat-feature-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
  }

  .cat-feature-title {
    font-size: 24px;
    font-weight: 700;
    color: #333;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .cat-feature-view-all {
    font-size: 13px;
    font-weight: 700;
    color: #2874f0;
    text-decoration: none;
    text-transform: uppercase;
    border-bottom: 1px solid #2874f0;
  }

  .cat-feature-grid {
    display: flex;
    gap: 30px;
    align-items: stretch;
  }

  .cat-feature-grid.banner-right {
    flex-direction: row-reverse;
  }

  .promo-banner-wrapper {
    position: relative;
    background: #f8f8f8;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    flex: 0 0 280px;
    width: 280px;
  }

  .promo-banner-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #f8f8f8;
  }

  .promo-badge {
    position: absolute;
    bottom: 80px;
    left: 0;
    background: rgba(0,0,0,0.7);
    color: #fff;
    padding: 10px 15px;
    font-size: 14px;
    font-weight: 600;
    max-width: 90%;
    z-index: 2;
  }

  .banner-icon-bar {
    background: #f1f1f1;
    display: flex;
    justify-content: space-around;
    padding: 10px 5px;
    border-top: 1px solid #ddd;
  }

  .banner-icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .banner-icon-item span {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    color: #666;
  }

  .product-mini-grid-wrapper {
    position: relative;
    overflow: hidden;
  }

  .product-mini-grid {
    display: flex;
    gap: 15px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    -ms-overflow-style: none;
    scrollbar-width: none;
    padding-bottom: 10px;
  }

  .product-mini-grid::-webkit-scrollbar {
    display: none;
  }

  .mini-product-card {
    width: calc(25% - 11.25px);
    min-width: calc(25% - 11.25px);
    flex: 0 0 auto;
    scroll-snap-align: start;
    text-align: left;
    position: relative;
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 35px;
    height: 50px;
    background: #fff;
    border: 1px solid #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .slider-btn--prev { left: -10px; }
  .slider-btn--next { right: -10px; }
  
  .slider-btn svg { width: 20px; height: 20px; fill: #2874f0; }

  @media screen and (max-width: 768px) {
    .mini-product-card { flex: 0 0 calc(50% - 10px); }
    .cat-feature-grid { flex-direction: column; }
    .promo-banner-wrapper { min-width: 100%; height: 300px; }
    .slider-btn { display: none; }
  }

  @media screen and (max-width: 500px) {
    .mini-product-card { flex: 0 0 calc(80% - 10px); }
  }

  /* High-Fidelity Card Styling */
  .mini-product-card .card__inner {
    height: 200px !important;
    padding-bottom: 0 !important;
    background: #fff !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    overflow: hidden;
    border-radius: 4px;
    position: relative;
  }

  .mini-product-card .card__inner img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    background: #fff;
  }

  .mini-product-card .card__heading {
    font-size: 14px !important;
    font-weight: 500 !important;
    margin: 12px 0 6px 0 !important;
    height: 3.2em;
    overflow: hidden;
    color: #212121 !important;
    line-height: 1.4 !important;
  }

  .mini-price-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .mini-price-current {
    font-weight: 700;
    color: #212121;
    font-size: 16px;
  }

  .mini-price-old {
    text-decoration: line-through;
    color: #878787;
    font-size: 13px;
  }

  .mini-price-discount {
    color: #388e3c;
    font-weight: 700;
    font-size: 13px;
    white-space: nowrap;
  }

  .mini-rating-badge {
    display: inline-flex;
    align-items: center;
    background: #388e3c;
    color: #fff;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 700;
    margin-top: 5px;
  }
{%- endstyle -%}

<div class="cat-feature-section" id="CatFeature-{{ section.id }}">
  <div class="cat-feature-header">
    <h2 class="cat-feature-title">{{ section.settings.title }}</h2>
    <a href="{{ section.settings.collection.url }}" class="cat-feature-view-all">View All</a>
  </div>

  <div class="cat-feature-grid {{ section.settings.banner_position }}">
    <div class="promo-banner-wrapper">
      {%- liquid
        assign default_banner = 'sidebar-washing.jpg'
        if section.settings.title contains 'Baby'
          assign default_banner = 'sidebar-baby.png'
        elsif section.settings.title contains 'Car'
          assign default_banner = 'sidebar-cleaning.jpg'
        endif
      -%}
      {%- if section.settings.banner_image != blank -%}
        <img src="{{ section.settings.banner_image | image_url: width: 600 }}" alt="{{ section.settings.banner_image.alt }}" loading="lazy">
      {%- else -%}
        <img src="{{ default_banner | asset_url }}" alt="Promo Banner" loading="lazy">
      {%- endif -%}
      
      {%- if section.settings.show_badge -%}
        <div class="promo-badge">{{ section.settings.promo_badge_text }}</div>
      {%- endif -%}
      
    </div>

    <div class="product-mini-grid-wrapper">
      <button class="slider-btn slider-btn--prev" aria-label="Previous">
        <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      </button>
      
      <div class="product-mini-grid">
        {%- if section.settings.collection != blank -%}
          {%- for product in section.settings.collection.products limit: 12 -%}
            <div class="mini-product-card">
              <a href="{{ product.url }}" class="full-unstyled-link">
                <div class="card__inner">
                  <img src="{{ product.featured_media | image_url: width: 400 }}" alt="{{ product.title }}" loading="lazy">
                </div>
                <h3 class="card__heading">{{ product.title | truncate: 45 }}</h3>
                <div class="mini-rating-badge">3.8 ★</div>
                <div class="mini-price-row">
                  <span class="mini-price-current">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="mini-price-old">{{ product.compare_at_price | money }}</span>
                    <span class="mini-price-discount">{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}% OFF</span>
                  {%- endif -%}
                </div>
              </a>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..8) -%}
             <div class="mini-product-card">
                <div style="background: #f2f2f2; height: 200px; display: flex; align-items: center; justify-content: center;">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
                <h3 class="card__heading">Example Product Name</h3>
                <div class="mini-rating-badge">4.2 ★</div>
                <div class="mini-price-row">
                  <span class="mini-price-current">₹249.00</span>
                  <span class="mini-price-old">₹599.00</span>
                  <span class="mini-price-discount">58% OFF</span>
                </div>
             </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button class="slider-btn slider-btn--next" aria-label="Next">
        <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    function initMiniSlider() {
      const container = document.querySelector('#CatFeature-{{ section.id }}');
      if (!container) return;
      const grid = container.querySelector('.product-mini-grid');
      const nextBtn = container.querySelector('.slider-btn--next');
      const prevBtn = container.querySelector('.slider-btn--prev');

      if (nextBtn && prevBtn && grid) {
        nextBtn.addEventListener('click', () => {
          const itemWidth = grid.querySelector('.mini-product-card').offsetWidth + 15;
          grid.scrollBy({ left: itemWidth, behavior: 'smooth' });
        });
        prevBtn.addEventListener('click', () => {
          const itemWidth = grid.querySelector('.mini-product-card').offsetWidth + 15;
          grid.scrollBy({ left: -itemWidth, behavior: 'smooth' });
        });
      }
    }
    initMiniSlider();
  })();
</script>

{% schema %}
{
  "name": "Category Feature Block",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Everyday Baby Needs"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Promo Banner Image"
    },
    {
      "type": "select",
      "id": "banner_position",
      "label": "Banner Position",
      "options": [
        { "value": "banner-left", "label": "Left" },
        { "value": "banner-right", "label": "Right" }
      ],
      "default": "banner-left"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show Badge",
      "default": true
    },
    {
      "type": "text",
      "id": "promo_badge_text",
      "label": "Badge Text",
      "default": "Protects Your Washing Machine"
    }
  ],
  "presets": [
    {
      "name": "Category Feature Block"
    }
  ]
}
{% endschema %}
