{%- style -%}
  .promo-grid-2x2 {
    padding: 40px 0;
    background-color: #ffffff;
  }
  .promo-grid-2x2__container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .promo-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .promo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .promo-item:hover img {
    transform: scale(1.05);
  }
  @media screen and (max-width: 749px) {
    .promo-grid-2x2__container {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<div class="promo-grid-2x2 page-width">
  <div class="promo-grid-2x2__container">
    <div class="promo-item">
      <img src="{{ 'promo-arm-sleeves.jpg' | asset_url }}" alt="Arm Sleeves Banner" loading="lazy" width="800" height="450">
    </div>
    <div class="promo-item">
      <img src="{{ 'promo-car-cover.jpg' | asset_url }}" alt="Car Cover Banner" loading="lazy" width="800" height="450">
    </div>
    <div class="promo-item">
      <img src="{{ 'promo-awejoy-baby.png' | asset_url }}" alt="AWEJOY Baby Banner" loading="lazy" width="800" height="450">
    </div>
    <div class="promo-item">
      <img src="{{ 'promo-microfiber-detail.jpg' | asset_url }}" alt="Microfiber Detail Banner" loading="lazy" width="800" height="450">
    </div>
  </div>
</div>

