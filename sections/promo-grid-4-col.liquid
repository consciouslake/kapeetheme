{%- style -%}
  .promo-grid-4-col {
    padding: 0 !important;
    max-width: var(--page-width);
    margin: 60px auto 100px auto !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
  }

  .promo-grid-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .promo-item {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .promo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .promo-item:hover img {
    transform: scale(1.05);
  }

  @media screen and (max-width: 989px) {
    .promo-grid-inner { grid-template-columns: 1fr 1fr; }
  }

  @media screen and (max-width: 480px) {
    .promo-grid-inner { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<div class="promo-grid-4-col">
  <div class="promo-grid-inner">
    {%- for block in section.blocks -%}
      <div class="promo-item">
        <a href="{{ block.settings.link | default: '#' }}">
          {%- liquid
             assign fallback_img = ''
             case forloop.index
               when 1
                 assign fallback_img = 'promo-awejoy-baby.png'
               when 2
                 assign fallback_img = 'promo-car-cover.jpg'
               when 3
                 assign fallback_img = 'promo-arm-sleeves.jpg'
               when 4
                 assign fallback_img = 'promo-microfiber-detail.jpg'
             endcase
          -%}
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt }}" loading="lazy">
          {%- elsif fallback_img != '' -%}
            <img src="{{ fallback_img | asset_url }}" alt="Promo Image" loading="lazy">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </a>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Promo Grid 4 Column",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "image",
      "name": "Promo Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Grid 4 Column",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
